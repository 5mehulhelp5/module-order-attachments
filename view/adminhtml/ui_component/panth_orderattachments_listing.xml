<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">panth_orderattachments_listing.panth_orderattachments_listing_data_source</item>
        </item>
    </argument>

    <settings>
        <spinner>panth_orderattachments_columns</spinner>
        <deps>
            <dep>panth_orderattachments_listing.panth_orderattachments_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="panth_orderattachments_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <updateUrl path="mui/index/render"/>
            <storageConfig>
                <param name="indexField" xsi:type="string">attachment_id</param>
            </storageConfig>
        </settings>
        <aclResource>Panth_OrderAttachments::attachment_view</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider" name="panth_orderattachments_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>attachment_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="panth_orderattachments_columns">
        <selectionsColumn name="ids" sortOrder="0">
            <settings>
                <indexField>attachment_id</indexField>
            </settings>
        </selectionsColumn>

        <column name="attachment_id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>

        <column name="thumbnail" class="Panth\OrderAttachments\Ui\Component\Listing\Column\Thumbnail" component="Magento_Ui/js/grid/columns/thumbnail" sortOrder="15">
            <settings>
                <label translate="true">Preview</label>
                <hasPreview>1</hasPreview>
                <sortable>false</sortable>
                <altField>original_filename</altField>
                <bodyTmpl>ui/grid/cells/thumbnail</bodyTmpl>
            </settings>
        </column>

        <column name="original_filename" sortOrder="20">
            <settings>
                <filter>text</filter>
                <label translate="true">File Name</label>
            </settings>
        </column>

        <column name="file_extension" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">Type</label>
            </settings>
        </column>

        <column name="file_size" sortOrder="40" class="Panth\OrderAttachments\Ui\Component\Listing\Column\FileSize">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Size</label>
            </settings>
        </column>

        <column name="product_id" class="Panth\OrderAttachments\Ui\Component\Listing\Column\ProductName" sortOrder="50">
            <settings>
                <filter>text</filter>
                <label translate="true">Product</label>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
            </settings>
        </column>

        <column name="order_id" sortOrder="60">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Order ID</label>
            </settings>
        </column>

        <column name="customer_email" sortOrder="70">
            <settings>
                <filter>text</filter>
                <label translate="true">Customer Email</label>
            </settings>
        </column>

        <column name="customer_note" sortOrder="75">
            <settings>
                <filter>text</filter>
                <label translate="true">Customer Note</label>
            </settings>
        </column>

        <column name="status" sortOrder="80" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <filter>select</filter>
                <label translate="true">Status</label>
                <dataType>select</dataType>
                <options>
                    <option name="active" xsi:type="array">
                        <item name="value" xsi:type="number">1</item>
                        <item name="label" xsi:type="string" translate="true">Active</item>
                    </option>
                    <option name="deleted" xsi:type="array">
                        <item name="value" xsi:type="number">0</item>
                        <item name="label" xsi:type="string" translate="true">Deleted</item>
                    </option>
                </options>
            </settings>
        </column>

        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date" sortOrder="90">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Uploaded</label>
                <dataType>date</dataType>
            </settings>
        </column>

        <actionsColumn name="actions" class="Panth\OrderAttachments\Ui\Component\Listing\Column\Actions" sortOrder="100">
            <settings>
                <label translate="true">Actions</label>
            </settings>
        </actionsColumn>
    </columns>
</listing>
