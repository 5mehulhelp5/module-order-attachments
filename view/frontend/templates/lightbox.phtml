 * Global lightbox for Order Attachment image popups (cart, minicart, order view)
 * Works on both Luma and Hyva — uses event delegation on document.body
 */
?>
<script>
(function() {
    'use strict';
    document.body.addEventListener('click', function(e) {
        var link = e.target.closest('[data-oa-lightbox]');
        if (!link) return;
        e.preventDefault();
        e.stopPropagation();

        var src = link.href || link.style.backgroundImage.replace(/url\(['"]?|['"]?\)/g, '');
        if (!src) return;

        // Create overlay
        var overlay = document.createElement('div');
        overlay.style.cssText = 'position:fixed;inset:0;z-index:2147483647;background:rgba(0,0,0,0.9);'
            + 'display:flex;align-items:center;justify-content:center;cursor:pointer;padding:20px;';
        overlay.onclick = function() { document.body.removeChild(overlay); document.body.style.overflow = ''; };

        // Image
        var img = document.createElement('img');
        img.src = src;
        img.style.cssText = 'max-width:90vw;max-height:85vh;border-radius:12px;'
            + 'box-shadow:0 8px 32px rgba(0,0,0,0.5);object-fit:contain;cursor:default;';
        img.onclick = function(ev) { ev.stopPropagation(); };

        // Close button
        var close = document.createElement('span');
        close.innerHTML = '&times;';
        close.style.cssText = 'position:fixed;top:16px;right:16px;color:#fff;font-size:28px;'
            + 'cursor:pointer;width:44px;height:44px;display:flex;align-items:center;'
            + 'justify-content:center;background:rgba(255,255,255,0.15);border-radius:50%;'
            + 'backdrop-filter:blur(4px);transition:background 0.2s;';
        close.onmouseover = function() { this.style.background = 'rgba(255,255,255,0.3)'; };
        close.onmouseout = function() { this.style.background = 'rgba(255,255,255,0.15)'; };

        overlay.appendChild(img);
        overlay.appendChild(close);
        document.body.appendChild(overlay);
        document.body.style.overflow = 'hidden';
    });

    // Escape key closes lightbox
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            var overlay = document.querySelector('[style*="z-index:2147483647"]');
            if (overlay) { document.body.removeChild(overlay); document.body.style.overflow = ''; }
        }
    });
})();
</script>
