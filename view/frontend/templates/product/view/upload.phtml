<script>
function oaUpload_<?= (int)$productId ?>() {
    const config = <?= /* @noEscape */ $uploadConfig ?>;
    return {
        config: config,
        files: [],
        customerNote: '',
        isDragging: false,
        notification: { show: false, message: '', type: 'success' },
        fileIdCounter: 0,
        get acceptString() { return this.config.allowedExtensions.map(ext => '.' + ext).join(','); },
        init() {
            this._form = document.querySelector('#product_addtocart_form, form[data-product-sku]');
            // Load existing attachments when editing a cart item
            if (this.config.existingAttachments && this.config.existingAttachments.length) {
                this.config.existingAttachments.forEach(att => {
                    this.files.push({
                        id: 'existing-' + (++this.fileIdCounter),
                        attachmentId: att.attachmentId,
                        name: att.name,
                        size: att.size,
                        extension: att.extension,
                        status: att.status,
                        progress: att.progress,
                        errorMessage: '',
                        nativeFile: null,
                    });
                });
                this.syncFormInputs();
            }
            if (this.config.existingNote) {
                this.customerNote = this.config.existingNote;
                this.syncFormInputs();
            }
        },
        // Keep hidden inputs in sync with uploaded files at all times
        syncFormInputs() {
            if (!this._form) return;
            // Sync attachment IDs
            this._form.querySelectorAll('input[name="order_attachment_ids[]"]').forEach(el => el.remove());
            this.files.filter(f => f.status === 'uploaded' && f.attachmentId).forEach(f => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'order_attachment_ids[]';
                input.value = f.attachmentId;
                this._form.appendChild(input);
            });
            // Sync customer note
            let noteInput = this._form.querySelector('input[name="order_attachment_note"]');
            if (this.customerNote) {
                if (!noteInput) {
                    noteInput = document.createElement('input');
                    noteInput.type = 'hidden';
                    noteInput.name = 'order_attachment_note';
                    this._form.appendChild(noteInput);
                }
                noteInput.value = this.customerNote;
            } else if (noteInput) {
                noteInput.remove();
            }
        },
        formatSize(bytes) {
            if (bytes >= 1048576) return (bytes / 1048576).toFixed(2) + ' MB';
            if (bytes >= 1024) return (bytes / 1024).toFixed(1) + ' KB';
            return bytes + ' B';
        },
        handleDrop(e) { this.isDragging = false; this.handleFiles(e.dataTransfer.files); },
        handleFileSelect(e) { this.handleFiles(e.target.files); e.target.value = ''; },
        handleFiles(fileList) {
            Array.from(fileList).forEach(file => {
                if (this.files.length >= this.config.maxFiles) {
                    this.showNotification('Maximum ' + this.config.maxFiles + ' files allowed', 'error');
                    return;
                }
                const ext = file.name.split('.').pop().toLowerCase();
                if (!this.config.allowedExtensions.includes(ext)) {
                    this.showNotification('"' + file.name + '" — file type not allowed', 'error');
                    return;
                }
                if (file.size > this.config.maxFileSizeBytes) {
                    this.showNotification('"' + file.name + '" exceeds ' + this.config.maxFileSize + 'MB limit', 'error');
                    return;
                }
                const entry = {
                    id: 'new-' + (++this.fileIdCounter), attachmentId: null,
                    name: file.name, size: file.size, extension: ext,
                    status: 'uploading', progress: 0, errorMessage: '', nativeFile: file
                };
                this.files.push(entry);
                this.uploadFile(entry);
            });
        },
        async uploadFile(fileEntry) {
            const fd = new FormData();
            fd.append('file', fileEntry.nativeFile);
            fd.append('product_id', this.config.productId);
            fd.append('form_key', hyva.getFormKey());
            if (this.customerNote) fd.append('customer_note', this.customerNote);
            // Honeypot: send the value of the hidden field (should always be empty for real users)
            const hp = this.$refs.oaHoneypot;
            if (hp) fd.append('oa_website_url', hp.value);
            const idx = this.files.findIndex(f => f.id === fileEntry.id);
            try {
                const xhr = new XMLHttpRequest();
                const self = this;
                const p = new Promise((resolve, reject) => {
                    xhr.upload.onprogress = (e) => { if (e.lengthComputable && idx >= 0) self.files[idx].progress = Math.round(e.loaded / e.total * 100); };
                    xhr.onload = () => { try { resolve(JSON.parse(xhr.responseText)); } catch(e) { reject(new Error('Bad response')); } };
                    xhr.onerror = () => reject(new Error('Network error'));
                });
                xhr.open('POST', this.config.uploadUrl);
                xhr.withCredentials = true;
                xhr.send(fd);
                const data = await p;
                if (data.success && idx >= 0) {
                    this.files[idx].status = 'uploaded';
                    this.files[idx].progress = 100;
                    this.files[idx].attachmentId = data.attachment_id;
                    this.syncFormInputs();
                    this.showNotification('"' + this.files[idx].name + '" uploaded', 'success');
                } else {
                    if (idx >= 0) { this.files[idx].status = 'error'; this.files[idx].errorMessage = data.message || 'Failed'; }
                    this.showNotification(data.message || 'Upload failed. Contact support if this persists.', 'error');
                }
            } catch (err) {
                if (idx >= 0) { this.files[idx].status = 'error'; this.files[idx].errorMessage = err.message; }
                this.showNotification('Upload error. Please try again or contact support.', 'error');
            }
        },
        async removeFile(index) {
            const file = this.files[index];
            if (!file) return;
            if (file.attachmentId && file.status === 'uploaded') {
                try {
                    const fd = new FormData();
                    fd.append('attachment_id', file.attachmentId);
                    fd.append('product_id', this.config.productId);
                    fd.append('form_key', hyva.getFormKey());
                    const res = await fetch(this.config.deleteUrl, { method: 'POST', body: fd, credentials: 'include' });
                    const data = await res.json();
                    if (data.success) { this.files.splice(index, 1); this.syncFormInputs(); this.showNotification('File removed', 'success'); }
                    else this.showNotification(data.message || 'Could not remove file', 'error');
                } catch (e) { this.showNotification('Error removing file. Please try again.', 'error'); }
            } else {
                this.files.splice(index, 1);
                this.syncFormInputs();
            }
        },
        showNotification(message, type) {
            this.notification = { show: true, message, type };
            setTimeout(() => { this.notification.show = false; }, 5000);
        }
    };
}
</script>

