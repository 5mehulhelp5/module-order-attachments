<script>
document.addEventListener('DOMContentLoaded', function() {
    'use strict';

    var config = <?= /* @noEscape */ $uploadConfig ?>;
    var uid = '<?= $escaper->escapeJs($uniqueId) ?>';
    var files = [];
    var fileIdCounter = 0;

    // DOM elements
    var wrap = document.getElementById(uid);
    var dropzone = document.getElementById(uid + '-dropzone');
    var fileInput = document.getElementById(uid + '-fileinput');
    var filesContainer = document.getElementById(uid + '-files');
    var counter = document.getElementById(uid + '-counter');
    var maxNotice = document.getElementById(uid + '-maxnotice');
    var noteBlock = document.getElementById(uid + '-noteblock');
    var noteTextarea = document.getElementById(uid + '-note');
    var noteCount = document.getElementById(uid + '-notecount');
    var honeypot = document.getElementById(uid + '-honeypot');
    var toast = document.getElementById(uid + '-toast');

    // Find form
    var form = document.querySelector('#product_addtocart_form') ||
               document.querySelector('form[data-product-sku]');

    // Get Magento form key from cookie
    function getFormKey() {
        var match = document.cookie.match(/form_key=([^;]+)/);
        if (match) return match[1];
        var el = document.querySelector('input[name="form_key"]');
        return el ? el.value : '';
    }

    function formatSize(bytes) {
        if (bytes >= 1048576) return (bytes / 1048576).toFixed(2) + ' MB';
        if (bytes >= 1024) return (bytes / 1024).toFixed(1) + ' KB';
        return bytes + ' B';
    }

    // ═══ Render ═══
    function render() {
        // Counter
        if (files.length > 0) {
            counter.textContent = files.length + '/' + config.maxFiles;
            counter.style.display = '';
        } else {
            counter.style.display = 'none';
        }

        // Dropzone vs max notice
        if (files.length >= config.maxFiles) {
            dropzone.style.display = 'none';
            maxNotice.style.display = '';
        } else {
            dropzone.style.display = '';
            maxNotice.style.display = 'none';
        }

        // Files list
        if (files.length > 0) {
            filesContainer.style.display = '';
            noteBlock.style.display = '';
        } else {
            filesContainer.style.display = 'none';
            noteBlock.style.display = 'none';
        }

        // Render file items
        filesContainer.innerHTML = '';
        files.forEach(function(file, index) {
            var div = document.createElement('div');
            div.className = 'oa-file';

            var statusClass = file.status === 'uploaded' ? 'success' : file.status === 'uploading' ? 'uploading' : 'error';
            var statusText = file.status === 'uploaded' ? 'Done' : file.status === 'uploading' ? (file.progress + '%') : (file.errorMessage || 'Failed');

            var statusIcon = '';
            if (file.status === 'uploaded') {
                statusIcon = '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="width:14px;height:14px;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>';
            } else if (file.status === 'uploading') {
                statusIcon = '<div style="width:14px;height:14px;border:2px solid rgba(13,148,136,0.2);border-top-color:var(--oa-primary);border-radius:50%;animation:oa-spin 0.8s linear infinite;"></div>';
            } else {
                statusIcon = '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="width:14px;height:14px;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>';
            }

            var progressHtml = '';
            if (file.status === 'uploading') {
                progressHtml = '<div class="oa-progress"><div class="oa-progress-bar animating" style="width:' + file.progress + '%"></div></div>';
            }

            div.innerHTML =
                '<div class="oa-file-icon"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg></div>' +
                '<div class="oa-file-info">' +
                    '<div class="oa-file-name">' + escapeHtml(file.name) + '</div>' +
                    '<div class="oa-file-meta"><span>' + formatSize(file.size) + '</span><span>&middot;</span><span>' + escapeHtml((file.extension || '').toUpperCase()) + '</span></div>' +
                    progressHtml +
                '</div>' +
                '<div class="oa-file-status ' + statusClass + '">' + statusIcon + '<span>' + escapeHtml(statusText) + '</span></div>' +
                '<button class="oa-file-delete" type="button" title="Remove file" data-index="' + index + '"' + (file.status === 'uploading' ? ' disabled' : '') + '>' +
                    '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>' +
                '</button>';

            filesContainer.appendChild(div);
        });

        // Bind delete buttons
        filesContainer.querySelectorAll('.oa-file-delete').forEach(function(btn) {
            btn.addEventListener('click', function() {
                removeFile(parseInt(this.getAttribute('data-index')));
            });
        });

        syncFormInputs();
    }

    function escapeHtml(str) {
        var div = document.createElement('div');
        div.appendChild(document.createTextNode(str));
        return div.innerHTML;
    }

    // ═══ Sync hidden form inputs ═══
    function syncFormInputs() {
        if (!form) return;
        // Remove old hidden inputs
        form.querySelectorAll('input[name="order_attachment_ids[]"]').forEach(function(el) { el.remove(); });
        // Add current
        files.forEach(function(f) {
            if (f.status === 'uploaded' && f.attachmentId) {
                var input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'order_attachment_ids[]';
                input.value = f.attachmentId;
                form.appendChild(input);
            }
        });
        // Sync note
        var noteVal = noteTextarea ? noteTextarea.value : '';
        var noteInput = form.querySelector('input[name="order_attachment_note"]');
        if (noteVal) {
            if (!noteInput) {
                noteInput = document.createElement('input');
                noteInput.type = 'hidden';
                noteInput.name = 'order_attachment_note';
                form.appendChild(noteInput);
            }
            noteInput.value = noteVal;
        } else if (noteInput) {
            noteInput.remove();
        }
    }

    // ═══ Show toast ═══
    var toastTimer = null;
    function showNotification(message, type) {
        if (toastTimer) clearTimeout(toastTimer);
        toast.className = 'oa-toast visible ' + type;
        toast.querySelector('.oa-toast-msg').textContent = message;
        toast.querySelector('.oa-toast-success-icon').style.display = type === 'success' ? '' : 'none';
        toast.querySelector('.oa-toast-error-icon').style.display = type === 'error' ? '' : 'none';
        toastTimer = setTimeout(function() {
            toast.className = 'oa-toast';
        }, 5000);
    }

    toast.querySelector('.close').addEventListener('click', function() {
        toast.className = 'oa-toast';
    });

    // ═══ Handle files ═══
    function handleFiles(fileList) {
        Array.from(fileList).forEach(function(file) {
            if (files.length >= config.maxFiles) {
                showNotification('Maximum ' + config.maxFiles + ' files allowed', 'error');
                return;
            }
            var ext = file.name.split('.').pop().toLowerCase();
            if (!config.allowedExtensions.includes(ext)) {
                showNotification('"' + file.name + '" — file type not allowed', 'error');
                return;
            }
            if (file.size > config.maxFileSizeBytes) {
                showNotification('"' + file.name + '" exceeds ' + config.maxFileSize + 'MB limit', 'error');
                return;
            }
            var entry = {
                id: 'new-' + (++fileIdCounter),
                attachmentId: null,
                name: file.name,
                size: file.size,
                extension: ext,
                status: 'uploading',
                progress: 0,
                errorMessage: '',
                nativeFile: file
            };
            files.push(entry);
            render();
            uploadFile(entry);
        });
    }

    // ═══ Upload file ═══
    function uploadFile(fileEntry) {
        var fd = new FormData();
        fd.append('file', fileEntry.nativeFile);
        fd.append('product_id', config.productId);
        fd.append('form_key', getFormKey());
        if (noteTextarea && noteTextarea.value) fd.append('customer_note', noteTextarea.value);
        if (honeypot) fd.append('oa_website_url', honeypot.value);

        var idx = files.indexOf(fileEntry);
        var xhr = new XMLHttpRequest();

        xhr.upload.onprogress = function(e) {
            if (e.lengthComputable && idx >= 0) {
                files[idx].progress = Math.round(e.loaded / e.total * 100);
                render();
            }
        };

        xhr.onload = function() {
            try {
                var data = JSON.parse(xhr.responseText);
                if (data.success && idx >= 0) {
                    files[idx].status = 'uploaded';
                    files[idx].progress = 100;
                    files[idx].attachmentId = data.attachment_id;
                    showNotification('"' + files[idx].name + '" uploaded', 'success');
                } else {
                    if (idx >= 0) {
                        files[idx].status = 'error';
                        files[idx].errorMessage = data.message || 'Failed';
                    }
                    showNotification(data.message || 'Upload failed.', 'error');
                }
            } catch (e) {
                if (idx >= 0) {
                    files[idx].status = 'error';
                    files[idx].errorMessage = 'Bad response';
                }
                showNotification('Upload error. Please try again.', 'error');
            }
            render();
        };

        xhr.onerror = function() {
            if (idx >= 0) {
                files[idx].status = 'error';
                files[idx].errorMessage = 'Network error';
            }
            showNotification('Upload error. Please try again.', 'error');
            render();
        };

        xhr.open('POST', config.uploadUrl);
        xhr.withCredentials = true;
        xhr.send(fd);
    }

    // ═══ Remove file ═══
    function removeFile(index) {
        var file = files[index];
        if (!file) return;

        if (file.attachmentId && file.status === 'uploaded') {
            var fd = new FormData();
            fd.append('attachment_id', file.attachmentId);
            fd.append('product_id', config.productId);
            fd.append('form_key', getFormKey());

            var xhr = new XMLHttpRequest();
            xhr.onload = function() {
                try {
                    var data = JSON.parse(xhr.responseText);
                    if (data.success) {
                        files.splice(index, 1);
                        render();
                        showNotification('File removed', 'success');
                    } else {
                        showNotification(data.message || 'Could not remove file', 'error');
                    }
                } catch (e) {
                    showNotification('Error removing file.', 'error');
                }
            };
            xhr.onerror = function() {
                showNotification('Error removing file.', 'error');
            };
            xhr.open('POST', config.deleteUrl);
            xhr.withCredentials = true;
            xhr.send(fd);
        } else {
            files.splice(index, 1);
            render();
        }
    }

    // ═══ Drag & drop ═══
    dropzone.addEventListener('dragover', function(e) {
        e.preventDefault();
        dropzone.classList.add('dragover');
    });
    dropzone.addEventListener('dragleave', function(e) {
        e.preventDefault();
        dropzone.classList.remove('dragover');
    });
    dropzone.addEventListener('drop', function(e) {
        e.preventDefault();
        dropzone.classList.remove('dragover');
        handleFiles(e.dataTransfer.files);
    });
    dropzone.addEventListener('click', function() {
        fileInput.click();
    });
    fileInput.addEventListener('change', function(e) {
        handleFiles(e.target.files);
        e.target.value = '';
    });

    // Set accept attribute
    fileInput.setAttribute('accept', config.allowedExtensions.map(function(ext) { return '.' + ext; }).join(','));

    // ═══ Note textarea ═══
    if (noteTextarea) {
        var noteTimer = null;
        noteTextarea.addEventListener('input', function() {
            noteCount.textContent = noteTextarea.value.length;
            if (noteTimer) clearTimeout(noteTimer);
            noteTimer = setTimeout(syncFormInputs, 300);
        });
    }

    // ═══ Load existing attachments (cart edit mode) ═══
    if (config.existingAttachments && config.existingAttachments.length) {
        config.existingAttachments.forEach(function(att) {
            files.push({
                id: 'existing-' + (++fileIdCounter),
                attachmentId: att.attachmentId,
                name: att.name,
                size: att.size,
                extension: att.extension,
                status: att.status,
                progress: att.progress,
                errorMessage: '',
                nativeFile: null
            });
        });
    }
    if (config.existingNote && noteTextarea) {
        noteTextarea.value = config.existingNote;
        noteCount.textContent = config.existingNote.length;
    }

    // Initial render
    render();
});

// Spinner animation
var oaSpinStyle = document.createElement('style');
oaSpinStyle.textContent = '@keyframes oa-spin { to { transform: rotate(360deg); } }';
document.head.appendChild(oaSpinStyle);
</script>
