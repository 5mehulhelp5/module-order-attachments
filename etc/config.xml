<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <panth_orderattachments>
            <general>
                <enabled>1</enabled>
            </general>
            <upload>
                <allowed_extensions>pdf,jpg,jpeg,png,gif,doc,docx,zip</allowed_extensions>
                <max_file_size>10</max_file_size>
                <max_files_per_item>3</max_files_per_item>
            </upload>
            <display>
                <upload_label>Attach Files</upload_label>
                <show_in_cart>1</show_in_cart>
                <show_in_checkout>1</show_in_checkout>
            </display>
        </panth_orderattachments>
    </default>
</config>
