<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="panth_order_attachment" resource="default" engine="innodb"
           comment="Panth Order Attachments">
        <column xsi:type="int" name="attachment_id" unsigned="true" nullable="false"
                identity="true" comment="Attachment ID"/>
        <column xsi:type="int" name="quote_item_id" unsigned="true" nullable="true"
                comment="Quote Item ID"/>
        <column xsi:type="int" name="order_item_id" unsigned="true" nullable="true"
                comment="Order Item ID"/>
        <column xsi:type="int" name="order_id" unsigned="true" nullable="true"
                comment="Order ID"/>
        <column xsi:type="int" name="product_id" unsigned="true" nullable="false"
                comment="Product ID"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="true"
                comment="Customer ID"/>
        <column xsi:type="varchar" name="customer_email" length="255" nullable="true"
                comment="Customer Email"/>
        <column xsi:type="varchar" name="original_filename" length="255" nullable="false"
                comment="Original Filename"/>
        <column xsi:type="varchar" name="stored_filename" length="255" nullable="false"
                comment="Stored Filename"/>
        <column xsi:type="varchar" name="file_path" length="500" nullable="false"
                comment="File Path"/>
        <column xsi:type="int" name="file_size" unsigned="true" nullable="false"
                comment="File Size in Bytes"/>
        <column xsi:type="varchar" name="mime_type" length="100" nullable="true"
                comment="MIME Type"/>
        <column xsi:type="varchar" name="file_extension" length="20" nullable="true"
                comment="File Extension"/>
        <column xsi:type="text" name="customer_note" nullable="true"
                comment="Customer Note"/>
        <column xsi:type="smallint" name="status" nullable="false" default="1"
                comment="Status"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP"
                on_update="true" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="attachment_id"/>
        </constraint>
        <index referenceId="PANTH_ORDER_ATTACHMENT_QUOTE_ITEM_ID" indexType="btree">
            <column name="quote_item_id"/>
        </index>
        <index referenceId="PANTH_ORDER_ATTACHMENT_ORDER_ITEM_ID" indexType="btree">
            <column name="order_item_id"/>
        </index>
        <index referenceId="PANTH_ORDER_ATTACHMENT_ORDER_ID" indexType="btree">
            <column name="order_id"/>
        </index>
        <index referenceId="PANTH_ORDER_ATTACHMENT_PRODUCT_ID" indexType="btree">
            <column name="product_id"/>
        </index>
        <index referenceId="PANTH_ORDER_ATTACHMENT_STATUS" indexType="btree">
            <column name="status"/>
        </index>
    </table>
</schema>
